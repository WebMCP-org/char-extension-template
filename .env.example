# ── Required ──
WXT_API_BASE=http://localhost:3000
WXT_CHAR_PUBLISHABLE_KEY=pk_live_YOUR_KEY
WXT_EXTENSION_NAME=My Extension

# ── OIDC ──
WXT_OIDC_CLIENT_ID=client_YOUR_ID
WXT_OIDC_AUTHORIZATION_ENDPOINT=https://api.workos.com/user_management/authorize
WXT_OIDC_TOKEN_ENDPOINT=https://api.workos.com/user_management/authenticate
WXT_OIDC_PROVIDER=authkit
WXT_OIDC_SCOPES=openid email profile

# ── Redirect proxy (required for WorkOS — chromiumapp.org URIs are rejected) ──
WXT_OIDC_REDIRECT_PROXY=${WXT_API_BASE}/extension-auth-callback

# ── Optional ──
# WXT_OIDC_ISSUER=
# WXT_CHROMIUM_PROFILE=
